<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.liu5413.leopardplugin</id>
    <name>leopard-plugin</name>
    <vendor>liu5413</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends>com.intellij.gradle</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.liu5413.leopardplugin.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="com.github.liu5413.leopardplugin.startup.MyProjectActivity" />
        <projectService serviceImplementation="com.github.liu5413.leopardplugin.settings.BuildNotificationSettings"/>
        <projectService serviceImplementation="com.github.liu5413.leopardplugin.settings.LogViewerSettings"/>
        <toolWindow factoryClass="com.github.liu5413.leopardplugin.toolWindow.PreviewLogToolWindowFactory" id="LogViewer" anchor="bottom" icon="/icons/preview-log.svg"/>
    </extensions>

    <actions>
        <action id="FireRunAction"
                class="com.github.liu5413.leopardplugin.actions.FireRunAction"
                text="Fire Run"
                description="Run with fire!">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="DebugBuildAction"
                class="com.github.liu5413.leopardplugin.actions.DebugBuildAction"
                text="Debug Build"
                description="Run gradle buildDebug">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="UninstallAction"
                class="com.github.liu5413.leopardplugin.actions.UninstallAction"
                text="Uninstall App"
                description="Uninstall app from device">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="ClearDataAction"
                class="com.github.liu5413.leopardplugin.actions.ClearDataAction"
                text="Clear Data"
                description="Clear app data on device">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="InstallAction"
                class="com.github.liu5413.leopardplugin.actions.InstallAction"
                text="Install App"
                description="Install app to device">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="ClaudeAction"
                class="com.github.liu5413.leopardplugin.actions.ClaudeAction"
                text="Claude Code"
                description="Open Claude Code via cfuse">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="CursorAction"
                class="com.github.liu5413.leopardplugin.actions.CursorAction"
                text="Cursor Agent"
                description="Open Cursor agent">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="CrashAction"
                class="com.github.liu5413.leopardplugin.actions.CrashAction"
                text="Crash Log"
                description="Watch crash logs via adb logcat">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="LogAction"
                class="com.github.liu5413.leopardplugin.actions.LogAction"
                text="Logcat"
                description="Capture logcat output to file">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="PreviewLogAction"
                class="com.github.liu5413.leopardplugin.actions.PreviewLogAction"
                text="Preview Log"
                description="Open log viewer with filtering and highlighting">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
        <action id="BuildNotificationToggleAction"
                class="com.github.liu5413.leopardplugin.actions.BuildNotificationToggleAction"
                text="Build Sound Notification"
                description="Toggle sound notification on Gradle build completion">
            <add-to-group group-id="MainToolbarRight" anchor="first"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
